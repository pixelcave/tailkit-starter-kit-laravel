{
  "name": "tailkit-starter-kit-laravel",
  "private": true,
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "update": "npm update --save && composer update && composer bump"
  },
  "prettier": {
    "tailwindStylesheet": "./resources/css/tailkit.css",
    "plugins": [
      "prettier-plugin-blade",
      "prettier-plugin-tailwindcss"
    ],
    "overrides": [
      {
        "files": [
          "*.blade.php"
        ],
        "options": {
          "parser": "blade",
          "htmlWhitespaceSensitivity": "ignore",
          "bladeKeepHeadAndBodyAtRoot": false
        }
      }
    ]
  },
  "devDependencies": {
    "@alpinejs/focus": "^3.15.8",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "alpinejs": "^3.15.8",
    "axios": "^1.13.6",
    "laravel-vite-plugin": "^3.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-blade": "^3.1.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.17",
    "vite": "^8.0.3"
  }
}
